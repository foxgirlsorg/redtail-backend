{
  "kind": "collectionType",
  "collectionName": "manga_titles",
  "info": {
    "singularName": "manga-title",
    "pluralName": "manga-titles",
    "displayName": "Manga Titles"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "release_year": {
      "type": "integer"
    },
    "authors": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::author.author",
      "inversedBy": "manga_titles"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "backdrop": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "chapters": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::manga-chapter.manga-chapter",
      "mappedBy": "title"
    },
    "release_status": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Онгоинг",
        "Завершён",
        "Анонс",
        "Приостановлен",
        "Заброшен",
        "Закончен"
      ]
    },
    "mangalib_url": {
      "type": "string",
      "regex": "https?:\\/\\/(www\\.)?[-a-zA-Z0-9@:%._\\+~#=]{1,256}\\.[a-zA-Z0-9()]{1,6}\\b([-a-zA-Z0-9()@:%_\\+.~#?&\\/=]*)"
    },
    "remanga_url": {
      "type": "string",
      "regex": "https?:\\/\\/(www\\.)?[-a-zA-Z0-9@:%._\\+~#=]{1,256}\\.[a-zA-Z0-9()]{1,6}\\b([-a-zA-Z0-9()@:%_\\+.~#?&\\/=]*)"
    },
    "readmanga_url": {
      "type": "string",
      "regex": "https?:\\/\\/(www\\.)?[-a-zA-Z0-9@:%._\\+~#=]{1,256}\\.[a-zA-Z0-9()]{1,6}\\b([-a-zA-Z0-9()@:%_\\+.~#?&\\/=]*)"
    },
    "hidden": {
      "type": "boolean",
      "required": false,
      "default": false
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true,
      "regex": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "alternative_names": {
      "type": "string"
    },
    "members_worked_ons": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::team-member.team-member",
      "inversedBy": "manga_titles"
    }
  }
}
