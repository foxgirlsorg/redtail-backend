{
  "kind": "collectionType",
  "collectionName": "team_members",
  "info": {
    "singularName": "team-member",
    "pluralName": "team-members",
    "displayName": "Team Members"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nickname": {
      "type": "string"
    },
    "role": {
      "type": "text"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "telegram_url": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "hidden": {
      "type": "boolean",
      "default": false
    },
    "manga_titles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::manga-title.manga-title",
      "mappedBy": "members_worked_ons"
    },
    "articles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::article.article",
      "mappedBy": "members_worked_on"
    }
  }
}
