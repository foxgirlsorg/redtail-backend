{
  "kind": "collectionType",
  "collectionName": "book_titles",
  "info": {
    "singularName": "book-title",
    "pluralName": "book-titles",
    "displayName": "Book Titles"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "release_year": {
      "type": "integer"
    },
    "authors": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::author.author",
      "mappedBy": "book_titles"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "backdrop": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "release_status": {
      "type": "enumeration",
      "enum": [
        "Онгоинг",
        "Завершён",
        "Анонс",
        "Приостановлен",
        "Заброшен",
        "Закончен"
      ]
    },
    "hidden": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true,
      "regex": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "alternative_names": {
      "type": "string"
    },
    "members_worked_on": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::team-member.team-member",
      "inversedBy": "books"
    },
    "chapters": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::book-chapter.book-chapter",
      "mappedBy": "title"
    },
    "type": {
      "type": "enumeration",
      "required": true,
      "default": "Книга",
      "enum": [
        "Книга",
        "Ранобэ",
        "Рассказ"
      ]
    }
  }
}
